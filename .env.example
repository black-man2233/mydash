# Copy to .env and fill in your values
DB_PASSWORD=Password123!
DB_NAME=MyDash

HUB_HTTP_PORT=9999
HUB_GRPC_PORT=7777
HUB_PUBLIC_URL=http://localhost:9999

SMS_PROVIDER=TextBelt   # TextBelt | Twilio | Vonage | ClickSend | SMSAPI
SMS_PHONE=+4591428084
SMS_API_KEY=textbelt    # TextBelt free key; replace with real key for other providers

# For enrolling the bundled agent (docker-compose --profile agent up)
AGENT_TOKEN=
AGENT_NAME=my-server
