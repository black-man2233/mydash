@using MyDash.Application.Repositories
@inject IEnrollmentTokenRepository Tokens
@inject IServerRepository Servers

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Rounded.Add" Class="mr-2" />Connect a Server
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_step == 1)
        {
            <MudText Typo="Typo.body1" Class="mb-3">Step 1: Name your server</MudText>
            <MudTextField @bind-Value="_serverName" Label="Server name" Placeholder="myserver"
                          Variant="Variant.Outlined" Required="true" Class="mb-2" />
            <MudTextField @bind-Value="_tags" Label="Tags (comma-separated)" Placeholder="home,linux"
                          Variant="Variant.Outlined" Class="mb-2" />
            <MudNumericField @bind-Value="_ttlMinutes" Label="Token TTL (minutes)" Min="10" Max="10080"
                             Variant="Variant.Outlined" />
        }
        else if (_step == 2)
        {
            <MudText Typo="Typo.body1" Class="mb-3">Step 2: Run the install command</MudText>
            <MudAlert Severity="Severity.Info" Class="mb-3">Token expires in @_ttlMinutes minutes. Keep it secret!</MudAlert>

            <MudTabs Elevation="0">
                <MudTabPanel Text="Linux">
                    <MudPaper Class="pa-2 mt-2" Style="background:#0d1117;">
                        <MudText Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#e6edf3;white-space:pre-wrap;">@_linuxCmd</MudText>
                    </MudPaper>
                </MudTabPanel>
                <MudTabPanel Text="macOS">
                    <MudPaper Class="pa-2 mt-2" Style="background:#0d1117;">
                        <MudText Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#e6edf3;white-space:pre-wrap;">@_linuxCmd</MudText>
                    </MudPaper>
                </MudTabPanel>
                <MudTabPanel Text="Windows">
                    <MudPaper Class="pa-2 mt-2" Style="background:#0d1117;">
                        <MudText Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#e6edf3;white-space:pre-wrap;">@_winCmd</MudText>
                    </MudPaper>
                </MudTabPanel>
                <MudTabPanel Text="Docker">
                    <MudPaper Class="pa-2 mt-2" Style="background:#0d1117;">
                        <MudText Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#e6edf3;white-space:pre-wrap;">@_dockerCmd</MudText>
                    </MudPaper>
                </MudTabPanel>
            </MudTabs>
        }
        else if (_step == 3)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                @if (_enrolled)
                {
                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h6" Class="mt-2">Connected!</MudText>
                    <MudText Typo="Typo.body2">@_enrolledName has joined the fleet.</MudText>
                }
                else
                {
                    <div class="pulse-ring"></div>
                    <MudText Typo="Typo.body1" Class="mt-3">Waiting for agent to connect…</MudText>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        @if (_step == 1)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep2"
                       Disabled="string.IsNullOrWhiteSpace(_serverName)">Next</MudButton>
        }
        else if (_step == 2)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep3">Waiting for connection…</MudButton>
        }
        else if (_step == 3 && _enrolled)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Done">Done</MudButton>
        }
    </DialogActions>
</MudDialog>

<style>
.pulse-ring {
    width: 60px; height: 60px; border-radius: 50%;
    border: 4px solid var(--mud-palette-primary);
    animation: pulse 1.2s ease-in-out infinite;
}
@@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.2); }
}
</style>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    int _step = 1;
    string _serverName = "";
    string _tags = "";
    int _ttlMinutes = 60;
    string _plainToken = "";
    string _linuxCmd = "", _winCmd = "", _dockerCmd = "";
    bool _enrolled;
    string _enrolledName = "";

    async Task GoToStep2()
    {
        var tags = _tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        _plainToken = await Tokens.IssueAsync(_serverName, tags, TimeSpan.FromMinutes(_ttlMinutes), default);
        _linuxCmd = $"curl -fsSL https://mydash.local/agent/install.sh | sudo bash -s -- --hub https://mydash.local --token {_plainToken} --name {_serverName}";
        _winCmd = $"irm https://mydash.local/agent/install.ps1 | iex -- --hub https://mydash.local --token {_plainToken} --name {_serverName}";
        _dockerCmd = $"docker run -d --name mydash-agent -e MYDASH_HUB=https://mydash.local -e MYDASH_TOKEN={_plainToken} -e MYDASH_NAME={_serverName} ghcr.io/user/mydash-agent:latest";
        _step = 2;
    }

    async Task GoToStep3()
    {
        _step = 3;
        await PollForEnrollment();
    }

    async Task PollForEnrollment()
    {
        for (int i = 0; i < 60; i++)
        {
            await Task.Delay(2000);
            var servers = await Servers.ListAllAsync();
            var match = servers.FirstOrDefault(s => s.Name.Equals(_serverName, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
            {
                _enrolled = true;
                _enrolledName = match.Name;
                StateHasChanged();
                return;
            }
            StateHasChanged();
        }
    }

    void Done() => MudDialog?.Close(DialogResult.Ok(true));
    void Cancel() => MudDialog?.Cancel();
}
