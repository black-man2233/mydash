@using MyDash.Application.Repositories
@inject IServiceRepository Services

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Service</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined" Class="mb-2" Required="true" />
        <MudNumericField @bind-Value="_port" Label="Port" Variant="Variant.Outlined" Class="mb-2" Required="true" Min="1" Max="65535" />
        <MudSelect @bind-Value="_type" Label="Type" Variant="Variant.Outlined" Class="mb-2">
            <MudSelectItem Value="@("native")">Native</MudSelectItem>
            <MudSelectItem Value="@("docker")">Docker</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_description" Label="Description" Variant="Variant.Outlined" Class="mb-2" />
        <MudTextField @bind-Value="_tags" Label="Tags (comma-separated)" Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
                   Disabled="@(string.IsNullOrWhiteSpace(_name) || _port <= 0)">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public string? ServerId { get; set; }

    string _name = "", _description = "", _tags = "", _type = "native";
    int _port;

    async Task Save()
    {
        if (!Guid.TryParse(ServerId, out var sid)) return;
        var svc = Domain.Entities.Service.Create(sid, _name, _port,
            _type == "docker" ? ServiceType.Docker : ServiceType.Native);
        svc.Description = _description;
        svc.Tags = _tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        await Services.AddAsync(svc);
        MudDialog?.Close(DialogResult.Ok(true));
    }

    void Cancel() => MudDialog?.Cancel();
}
