@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IServerRepository Servers
@inject IAuditRepository Audit

<PageTitle>Dashboard — MyDash</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Dashboard</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">SERVERS</MudText>
            <MudText Typo="Typo.h4">@_servers.Count</MudText>
            <MudText Typo="Typo.body2">@_serversUp up · @(_servers.Count - _serversUp) down</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">SERVICES</MudText>
            <MudText Typo="Typo.h4">@_totalServices</MudText>
            <MudText Typo="Typo.body2">across all servers</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">AVG CPU</MudText>
            <MudText Typo="Typo.h4">@(_avgCpu.ToString("0.0"))%</MudText>
            <MudText Typo="Typo.body2">across online servers</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">AVG MEM</MudText>
            <MudText Typo="Typo.h4">@(_avgMem.ToString("0.0"))%</MudText>
            <MudText Typo="Typo.body2">across online servers</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mt-6 mb-3">Servers</MudText>
<MudGrid>
    @foreach (var server in _servers)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Class="server-card">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Style="@($"background:{server.Color};")">@server.InitialChar</MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">@server.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@server.FullName</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(server.Status == ServerStatus.Up ? Color.Success : server.Status == ServerStatus.Down ? Color.Error : Color.Warning)">
                            @server.Status
                        </MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">CPU @server.CpuPercent.ToString("0")% · MEM @server.MemPercent.ToString("0")% · DISK @server.DiskPercent.ToString("0")%</MudText>
                    <MudText Typo="Typo.caption" Style="font-family:'JetBrains Mono',monospace">@server.TailscaleHost</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="@($"/server/{server.Id}")" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">Details</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

<MudText Typo="Typo.h6" Class="mt-6 mb-3">Recent Activity</MudText>
<MudPaper Elevation="1">
    <MudTable Items="_recentAudit" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Time</MudTh>
            <MudTh>Action</MudTh>
            <MudTh>Target</MudTh>
            <MudTh>IP</MudTh>
            <MudTh>Outcome</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem">@context.At.LocalDateTime.ToString("HH:mm:ss")</MudTd>
            <MudTd>@context.Action</MudTd>
            <MudTd>@context.Target</MudTd>
            <MudTd Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem">@context.Ip</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.Outcome == "ok" ? Color.Success : Color.Error)">@context.Outcome</MudChip>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    List<Server> _servers = new();
    List<AuditEntry> _recentAudit = new();
    int _serversUp, _totalServices;
    double _avgCpu, _avgMem;

    protected override async Task OnInitializedAsync()
    {
        _servers = await Servers.ListAllAsync();
        _recentAudit = await Audit.ListAsync(10);
        _serversUp = _servers.Count(s => s.Status == ServerStatus.Up);
        _totalServices = _servers.Sum(s => s.Services.Count);
        var online = _servers.Where(s => s.Status == ServerStatus.Up).ToList();
        _avgCpu = online.Any() ? online.Average(s => s.CpuPercent) : 0;
        _avgMem = online.Any() ? online.Average(s => s.MemPercent) : 0;
    }
}
