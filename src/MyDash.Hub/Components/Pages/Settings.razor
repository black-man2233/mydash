@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IUserPreferencesRepository Prefs
@inject IServerRepository Servers
@inject ISnackbar Snackbar
@inject Microsoft.Extensions.Options.IOptions<MyDash.Application.Options.SmsOptions> SmsOpts

<PageTitle>Settings — MyDash</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

<MudGrid>
    <MudItem xs="12" md="8">

        <MudText Typo="Typo.h6" Class="mb-2">SMS Provider</MudText>
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudRadioGroup @bind-Value="_smsProvider">
                <MudGrid>
                    @foreach (var p in new[] { "TextBelt", "Twilio", "Vonage", "ClickSend", "SMSAPI" })
                    {
                        <MudItem xs="12" sm="6">
                            <MudPaper Outlined="true" Class="pa-2">
                                <MudRadio Value="@p" Color="Color.Primary">@p</MudRadio>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudRadioGroup>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Current: @SmsOpts.Value.Provider. Change via appsettings.json and restart the hub.
            </MudText>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">Appearance</MudText>
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudSelect @bind-Value="_prefs.Theme" Label="Theme" Variant="Variant.Outlined" Class="mb-2">
                <MudSelectItem Value="@("Dark")">Dark</MudSelectItem>
                <MudSelectItem Value="@("Light")">Light</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="_prefs.DefaultServiceView" Label="Default Service View" Variant="Variant.Outlined" Class="mb-2">
                <MudSelectItem Value="@("cards")">Cards</MudSelectItem>
                <MudSelectItem Value="@("table")">Table</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="_prefs.Density" Label="Density" Variant="Variant.Outlined">
                <MudSelectItem Value="@("compact")">Compact</MudSelectItem>
                <MudSelectItem Value="@("normal")">Normal</MudSelectItem>
                <MudSelectItem Value="@("comfortable")">Comfortable</MudSelectItem>
            </MudSelect>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">Notifications</MudText>
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudSwitch @bind-Value="_prefs.NotifyOnNewPorts" Color="Color.Primary" Label="Notify on new ports discovered" />
            <MudSwitch @bind-Value="_prefs.NotifyOnDisconnect" Color="Color.Primary" Label="Notify when agent disconnects" />
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">Scheduled Scan</MudText>
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudTextField @bind-Value="_prefs.ScanSchedule" Label="Cron schedule (e.g. 0 3 * * *)"
                          Variant="Variant.Outlined" Placeholder="0 3 * * *"
                          HelperText="Leave empty to disable scheduled scans" />
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">Servers</MudText>
        <MudPaper Elevation="1" Class="pa-0 mb-4">
            <MudTable Items="_servers" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Fingerprint</MudTh>
                    <MudTh>Enrolled</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip></MudTd>
                    <MudTd Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem">@context.AgentFingerprint</MudTd>
                    <MudTd Style="font-family:'JetBrains Mono',monospace;font-size:0.75rem">@context.EnrolledAt.ToString("yyyy-MM-dd")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save Preferences</MudButton>
    </MudItem>
</MudGrid>

@code {
    UserPreferences _prefs = new();
    List<Server> _servers = new();
    string _smsProvider = "TextBelt";

    protected override async Task OnInitializedAsync()
    {
        _prefs = await Prefs.GetAsync();
        _servers = await Servers.ListAllAsync();
        _smsProvider = SmsOpts.Value.Provider;
    }

    async Task Save()
    {
        await Prefs.UpdateAsync(_prefs);
        Snackbar.Add("Preferences saved", Severity.Success);
    }

    Color StatusColor(ServerStatus s) => s switch
    {
        ServerStatus.Up => Color.Success,
        ServerStatus.Down => Color.Error,
        ServerStatus.Degraded => Color.Warning,
        _ => Color.Default,
    };
}
