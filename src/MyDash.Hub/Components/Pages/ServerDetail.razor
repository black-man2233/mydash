@page "/server/{Id}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IServerRepository Servers
@inject IServiceRepository Services
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<PageTitle>@_server?.Name — MyDash</PageTitle>

@if (_server is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
        <MudAvatar Size="Size.Large" Style="@($"background:{_server.Color};")">@_server.InitialChar</MudAvatar>
        <div>
            <MudText Typo="Typo.h5">@_server.Name</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-family:'JetBrains Mono',monospace">@_server.TailscaleHost</MudText>
        </div>
        <MudSpacer />
        <MudChip T="string" Color="@StatusColor(_server.Status)">@_server.Status</MudChip>
    </MudStack>

    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.caption">CPU</MudText><MudText Typo="Typo.h5">@_server.CpuPercent.ToString("0.0")%</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.caption">MEM</MudText><MudText Typo="Typo.h5">@_server.MemPercent.ToString("0.0")%</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.caption">DISK</MudText><MudText Typo="Typo.h5">@_server.DiskPercent.ToString("0.0")%</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.caption">UPTIME</MudText><MudText Typo="Typo.h5">@FormatUptime(_server.UptimeSeconds)</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudStack Row="true" Class="mb-3" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_nameFilter" Label="Filter services" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Rounded.Search" Variant="Variant.Outlined"
                      Immediate="true" Class="flex-grow-1" />
        <MudToggleGroup T="string" @bind-Value="_viewMode" SelectionMode="SelectionMode.SingleSelection">
            <MudToggleItem Value="@("cards")"><MudIcon Icon="@Icons.Material.Rounded.GridView" Size="Size.Small" /></MudToggleItem>
            <MudToggleItem Value="@("table")"><MudIcon Icon="@Icons.Material.Rounded.TableRows" Size="Size.Small" /></MudToggleItem>
        </MudToggleGroup>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
                   OnClick="AddService">Add Service</MudButton>
    </MudStack>

    @if (_viewMode == "cards")
    {
        <MudGrid>
            @foreach (var svc in FilteredServices)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudIcon Icon="@svc.IconGlyph" Style="@($"color:{svc.IconColor}")" />
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">@svc.Name</MudText>
                                <MudText Typo="Typo.caption" Style="font-family:'JetBrains Mono',monospace">:@svc.Port</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(svc.Status)">@svc.Status</MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardActions>
                            <MudButton Size="Size.Small" OnClick="@(() => OpenService(svc))">Open</MudButton>
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => RemoveService(svc))" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudTable Items="FilteredServices" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Port</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd Style="font-family:'JetBrains Mono',monospace">@context.Port</MudTd>
                <MudTd>@context.Type</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip></MudTd>
                <MudTd>
                    <MudButton Size="Size.Small" OnClick="@(() => OpenService(context))">Open</MudButton>
                    <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => RemoveService(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    [Parameter] public string Id { get; set; } = "";

    Server? _server;
    List<Domain.Entities.Service> _services = new();
    string _viewMode = "cards";
    string _nameFilter = "";

    IEnumerable<Domain.Entities.Service> FilteredServices =>
        string.IsNullOrEmpty(_nameFilter) ? _services :
        _services.Where(s => s.Name.Contains(_nameFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (Guid.TryParse(Id, out var id))
        {
            _server = await Servers.GetByIdAsync(id);
            _services = await Services.ListByServerAsync(id);
        }
    }

    void OpenService(Domain.Entities.Service svc)
    {
        var url = $"http://{_server?.TailscaleHost}:{svc.Port}";
        Snackbar.Add($"Opening {url}", Severity.Info);
    }

    async Task RemoveService(Domain.Entities.Service svc)
    {
        await Services.DeleteAsync(svc.Id);
        _services.Remove(svc);
        Snackbar.Add($"Service {svc.Name} removed", Severity.Info);
    }

    async Task AddService()
    {
        await Dialog.ShowAsync<AddServiceDialog>("Add Service", new DialogParameters
        {
            { "ServerId", _server?.Id.ToString() }
        });
        if (_server is not null)
            _services = await Services.ListByServerAsync(_server.Id);
    }

    string FormatUptime(long seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.Days > 0 ? $"{ts.Days}d {ts.Hours}h" : $"{ts.Hours}h {ts.Minutes}m";
    }

    Color StatusColor(ServerStatus s) => s switch
    {
        ServerStatus.Up => Color.Success,
        ServerStatus.Down => Color.Error,
        ServerStatus.Degraded => Color.Warning,
        _ => Color.Default,
    };
}
